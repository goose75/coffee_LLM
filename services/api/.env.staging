# ── Staging Environment Configuration ──────────────────────────────────────
# Used for Wednesday-Friday testing of Track 1 (Browser) and Track 2 (LLM)
# Date: May 29-31, 2026
# Test Duration: 3 days (staging validation + production deployment)

# ── App ──────────────────────────────────────────────────────────────────────
APP_ENV=staging
DEBUG=true
AUTO_CREATE_TABLES=false

# ── Database ──────────────────────────────────────────────────────────────────
# Uses same database as development (coffee_platform)
# Staging pipelines will write to production schema for Week 2 testing
DATABASE_URL=postgresql+asyncpg://coffee:coffee@postgres:5432/coffee_platform
DATABASE_POOL_SIZE=15
DATABASE_MAX_OVERFLOW=30

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── CORS ──────────────────────────────────────────────────────────────────────
CORS_ORIGINS=["http://localhost:3000","http://localhost:3001","http://localhost:8000"]

# ── Object Storage ────────────────────────────────────────────────────────────
STORAGE_BACKEND=local
STORAGE_LOCAL_PATH=./raw_storage

# ── LLM ───────────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-placeholder-for-local-testing
LLM_MODEL=claude-opus-4-1

# ── LLM Pipeline (Track 2) ────────────────────────────────────────────────────
LLM_PROMPT_VERSION=v2.0.0
LLM_DOMAIN_CONTEXT_ENABLED=true
LLM_CONFIDENCE_THRESHOLD=0.25
LLM_FALLBACK_TO_DETERMINISTIC=true
LLM_COST_TRACKING_ENABLED=true
LLM_COST_ALERT_THRESHOLD_USD=50.00

# ── Browser Automation (Track 1) ──────────────────────────────────────────────
BROWSER_MAX_CONTEXTS=10
BROWSER_RENDER_TIMEOUT_MS=10000
BROWSER_NETWORK_TIMEOUT_MS=8000
BROWSER_WAIT_SELECTOR_TIMEOUT_MS=5000
BROWSER_HEADLESS=true
BROWSER_MEMORY_LIMIT_MB=500
BROWSER_LOG_LEVEL=info

# ── Embeddings ────────────────────────────────────────────────────────────────
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536

# ── Confidence Thresholds ─────────────────────────────────────────────────────
CONFIDENCE_AUTO_ACCEPT=0.92
CONFIDENCE_REVIEW_QUEUE=0.75

# ── Worker Configuration ──────────────────────────────────────────────────────
WORKER_COUNT=6
LOG_LEVEL=INFO
