# ── App ──────────────────────────────────────────────────────────────────────
APP_ENV=development
DEBUG=true
AUTO_CREATE_TABLES=false

# ── Database ──────────────────────────────────────────────────────────────────
# asyncpg driver used by FastAPI; psycopg2 used by Alembic (see env.py)
DATABASE_URL=postgresql+asyncpg://coffee:coffee@postgres:5432/coffee_platform
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list handled in config.py
CORS_ORIGINS=["http://localhost:3000","http://localhost:3001"]

# ── Object Storage ────────────────────────────────────────────────────────────
STORAGE_BACKEND=local          # "local" | "s3"
STORAGE_LOCAL_PATH=./raw_storage
AWS_BUCKET_NAME=
AWS_REGION=eu-west-2

# ── LLM ───────────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-placeholder-for-local-testing
LLM_MODEL=claude-opus-4-1

# ── Embeddings ────────────────────────────────────────────────────────────────
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536

# ── Confidence Thresholds ─────────────────────────────────────────────────────
CONFIDENCE_AUTO_ACCEPT=0.92
CONFIDENCE_REVIEW_QUEUE=0.75
