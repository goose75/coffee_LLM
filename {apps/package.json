{
  "name": "coffee-platform",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:web": "pnpm --filter public-site dev",
    "dev:admin": "pnpm --filter admin-app dev",
    "dev:all": "concurrently \"pnpm dev:web\" \"pnpm dev:admin\"",
    "build:web": "pnpm --filter public-site build",
    "build:admin": "pnpm --filter admin-app build",
    "build:all": "pnpm --filter public-site build && pnpm --filter admin-app build",
    "lint": "pnpm --filter '*' lint",
    "type-check": "pnpm --filter '*' type-check"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=8.0.0"
  },
  "packageManager": "pnpm@8.15.0"
}
