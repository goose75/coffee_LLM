{
  "$schema": "https://railway.app/schema.json",
  "build": {
    "builder": "nixpacks",
    "buildCommand": "cd apps/public-site && npm install && npm run build"
  },
  "deploy": {
    "numReplicas": 1,
    "startCommand": "cd apps/public-site && npm run start",
    "restartPolicyMaxRetries": 5
  },
  "env": {
    "NODE_ENV": "production"
  }
}
