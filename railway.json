{
  "$schema": "https://railway.app/schema.json",
  "build": {
    "builder": "dockerfile",
    "buildCommand": "docker build -t coffee-api ./services/api",
    "dockerfilePath": "services/api/Dockerfile",
    "context": "./services/api"
  },
  "deploy": {
    "numReplicas": 1
  },
  "env": {
    "APP_ENV": "production",
    "DEBUG": "false",
    "AUTO_CREATE_TABLES": "true"
  }
}
